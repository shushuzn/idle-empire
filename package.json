{
  "name": "idle-empire",
  "private": true,
  "version": "2.2.0",
  "description": "Premium idle incremental game built with Svelte 5",
  "type": "module",
  "repository": "https://github.com/shushuzn/idle-empire.git",
  "keywords": [
    "idle",
    "game",
    "incremental",
    "svelte",
    "svelte5"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && node -e \"import('fs').then(fs=>fs.copyFileSync('dist-upload/index.html','dist/index.html'))\"",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@testing-library/svelte": "^5.3.1",
    "jsdom": "^29.0.1",
    "svelte": "^5.0.0",
    "vite": "^5.4.0",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "pako": "^2.1.0"
  }
}
